# Data
# All data/raw/ is COMMITTED to the repo because Streamlit Cloud needs
# it to run the deployed app. See .claude/rules/deployment.md for the
# full reasoning. Only the extras/ subfolder is excluded.
data/raw/extras/

# Generated reports
# These are regenerated by running the engine; do NOT commit them
# during development, but DO commit them before pushing for a
# Streamlit Cloud deployment (the deployed app reads from reports/).
# Toggle this line when preparing a release.
# reports/   <-- toggled OFF for Phase 4 deployment commit

# Streamlit secrets (never commit credentials)
.streamlit/secrets.toml

# Claude Code local session config (permissions, not project code)
.claude/settings.local.json

# Environment variables
.env
.env.local
